# unsorry data source (optional — defaults to https://unsorry.agentics.org.nz/docs)
NEXT_PUBLIC_UNSORRY_BASE_URL=https://unsorry.agentics.org.nz/docs

# Supabase (OPTIONAL — only needed for the admin prize console; the public,
# read-only site runs without it via the in-repo prize config fallback)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Site URL for social media previews (Open Graph)
NEXT_PUBLIC_SITE_URL=https://swarm.unsorry.agentics.org.nz

# Branding (optional)
NEXT_PUBLIC_GUILD_LOGO_URL=
NEXT_PUBLIC_GUILD_NAME=
NEXT_PUBLIC_GUILD_LINK=

# Initial GM (for seeding)
INITIAL_GM_EMAIL=

# Guild Events (optional - Lu.ma ICS feed URL)
NEXT_PUBLIC_GUILD_EVENTS_FEED_URL=

# Mentorship (optional - external signup URL)
NEXT_PUBLIC_MENTORSHIP_SIGNUP_URL=

# Email (Mailjet - required for email features)
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
EMAIL_FROM_ADDRESS=agentics@cgee.nz
